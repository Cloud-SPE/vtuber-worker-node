# Copy to .env and fill the REQUIRED values. compose.prod.yaml reads this.
# See docs/operations/running-with-docker.md for the full walkthrough.

# ─── Images ───────────────────────────────────────────────────────────────
# Explicitly pin the vtuber images you want to deploy.
# `payment-daemon` can usually track the known-good default below.
VTUBER_WORKER_IMAGE=REQUIRED-tztcloud/livepeer-vtuber-worker-node:<tag>
SESSION_RUNNER_IMAGE=REQUIRED-tztcloud/livepeer-vtuber-session-runner:<tag>
PAYMENT_DAEMON_IMAGE_TAG=v3.1.8

# ─── Chain RPC (Arbitrum One mainnet) ────────────────────────────────────
# Read-write JSON-RPC endpoint. The receiver-mode daemon needs write
# access to submit ticket-redemption transactions.
# Public endpoint works for low-volume:    https://arb1.arbitrum.io/rpc
# Provider endpoints (recommended):        https://arb-mainnet.g.alchemy.com/v2/<KEY>
#                                          https://arbitrum-mainnet.infura.io/v3/<KEY>
CHAIN_RPC=REQUIRED-https://arb1.arbitrum.io/rpc-or-your-provider

# ─── Recipient keystore (V3 JSON, encrypted) ─────────────────────────────
# The address that receives tickets. Must match the
# `payment_daemon.recipient_eth_address` value in worker.yaml.
# Generate with: geth account new --keystore .
# Mount the JSON file + a separate file containing the password.
# Both default to ./keystore.json + ./keystore-password in the working
# directory; override here if your VPS uses a different path.
RECIPIENT_KEYSTORE_PATH=./keystore.json
RECIPIENT_KEYSTORE_PASSWORD_PATH=./keystore-password

# ─── Worker.yaml path on the host ────────────────────────────────────────
# Single source of truth for capabilities + prices + backend URLs +
# recipient address. Both the daemon and the worker process read it.
WORKER_YAML_PATH=./worker.yaml

# ─── Host-side port published for the worker ─────────────────────────────
# Cloudflared (running outside docker) reaches the worker via
# http://<vps-ip>:${WORKER_HOST_PORT}. If cloudflared runs as a
# container on the cf-tunnel network defined in compose.prod.yaml, you
# can drop the published port — cloudflared then reaches the worker by
# container name (http://vtuber-worker:8080).
WORKER_HOST_PORT=8080

# ─── Logging ─────────────────────────────────────────────────────────────
# error | warn | info | debug
DAEMON_LOG_LEVEL=info
WORKER_LOG_LEVEL=info
SESSION_RUNNER_LOG_LEVEL=info
SESSION_RUNNER_LOG_FORMAT=json

# ─── Session-runner mode ─────────────────────────────────────────────────
# Start conservative for first production: Chromium renderer, mock LLM/TTS
# until the payment/open/topup/end path is proven on the host. When the
# bridge is sending `openai_bridge_url` + `session_child_bearer` per session,
# you can switch these to `livepeer`.
SESSION_RUNNER_RENDERER=chromium
SESSION_RUNNER_LLM=mock
SESSION_RUNNER_TTS=mock

# Optional fallback only. In production, nested LLM/TTS requests should
# normally use the bridge-supplied per-session values instead of these
# process-level env vars.
# SESSION_RUNNER_OPENAI_BRIDGE_URL=https://your-openai-livepeer-bridge
# SESSION_RUNNER_OPENAI_BRIDGE_KEY=vtbs_...

# ─── Metrics (Prometheus /metrics, off by default) ───────────────────────
# Worker port allocation per livepeer-modules-conventions/port-allocation.md
# is :9093. Uncomment to enable; the worker will bind on this port and
# expose Prometheus exposition at /metrics. Empty disables metrics.
# METRICS_PORT=9093
